# OpenCode local config (user-specific, may contain secrets)
.opencode/auth.json
.opencode/state/

# Runtime artifacts (regenerated)
arxiv_cache/
outputs/
*-workspace/
notes/
*.log
*.db

# Traces & checkpoints (large, regenerated)
.opencode/traces/*
!.opencode/traces/.gitkeep
.opencode/checkpoints/*
!.opencode/checkpoints/.gitkeep
.opencode/proposals/*
!.opencode/proposals/.gitkeep

# Eval results (large, regenerated)
evals/results/*
!evals/results/.gitkeep

# Node
.opencode/node_modules/

# OS files
.DS_Store
Thumbs.db

# Legacy
*.backup
*.v0
