# OpenCode local config (user-specific, may contain secrets)
.opencode/auth.json
.opencode/state/

# Runtime artifacts (regenerated)
arxiv_cache/
outputs/
*-workspace/
notes/
*.log
*.db

# Traces & checkpoints (large, regenerated)
.opencode/traces/*
!.opencode/traces/.gitkeep
!.opencode/traces/README.md
.opencode/checkpoints/*
!.opencode/checkpoints/.gitkeep
!.opencode/checkpoints/README.md
.opencode/proposals/*
!.opencode/proposals/.gitkeep
!.opencode/proposals/README.md

# Node
.opencode/node_modules/
.opencode/package.json
.opencode/package-lock.json
.opencode/bun.lockb
.opencode/bun.lock

# OS files
.DS_Store
Thumbs.db

# Legacy
*.backup
*.v0

.env
opencode.json